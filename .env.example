# Copia este archivo a .env y rellena tus valores
# cp .env.example .env

# ── Gemini ──────────────────────────────────────────────────
# Consíguela gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...

# ── Usuario por defecto (CLI y bot Telegram) ──────────────────
CLI_USER_EMAIL=tu@email.com

# ── Telegram Bot ──────────────────────────────────────────────
# Token: crea el bot con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABC...
# Tu chat_id personal: habla con @RawDataBot y te lo envía
TELEGRAM_ALLOWED_CHAT_ID=0

# ── Streamlit / Panel Admin (Google OAuth) ────────────────────
ALLOWED_EMAIL=tu@email.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
COOKIE_SECRET=cambia-esto-por-algo-aleatorio
OAUTH_REDIRECT_URI=https://tu-servicio.run.app/oauth2callback
